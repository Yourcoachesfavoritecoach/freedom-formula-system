# ============================================================
# Freedom Formula System — Environment Variables
# ============================================================
# Copy this file to .env and fill in all values before running.
# Never commit the .env file to version control.
# ============================================================

# --- Fit Biz Solutions (Agency Level) ---
FBS_AGENCY_API_KEY=your_fit_biz_solutions_agency_api_key
GHL_AGENCY_ID=your_fit_biz_solutions_agency_id

# --- The Coaching Dept. (Sub-Account) ---
COACHING_DEPT_LOCATION_ID=your_coaching_dept_sub_account_location_id

# --- Google Ads API ---
GOOGLE_ADS_DEVELOPER_TOKEN=your_google_ads_developer_token
GOOGLE_ADS_CLIENT_ID=your_google_ads_oauth_client_id
GOOGLE_ADS_CLIENT_SECRET=your_google_ads_oauth_client_secret
GOOGLE_ADS_REFRESH_TOKEN=your_google_ads_oauth_refresh_token

# --- Meta Ads Manager API ---
META_ACCESS_TOKEN=your_meta_long_lived_access_token

# --- GHL Workflow IDs ---
GHL_REENGAGEMENT_WORKFLOW_ID=usman_provides_this_after_building_workflow

# --- Form Hosting ---
FORM_BASE_URL=https://your-domain.com/forms/weekly-performance-form.html

# --- Email Sender Config ---
SENDER_EMAIL=team@thecoachingdept.com
SENDER_NAME=The Coaching Dept.

# --- Internal Recipients ---
DAVE_EMAIL=dave@thecoachingdept.com
HEATHER_EMAIL=heather@thecoachingdept.com
